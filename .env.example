# Copy this file to .env and fill in your values

# Required: OpenAI API key for sampling + elicitation LLM calls
OPENAI_API_KEY=sk-...

# Optional: path to the Python interpreter in your project venv
# Defaults to .venv/Scripts/python.exe (Windows) or .venv/bin/python (Unix)
# SERVER_PYTHON=C:\Users\you\Projects\SpeculativeSystemDesigner\.venv\Scripts\python.exe

# Optional: Python module path for the MCP server
# SERVER_MODULE=server.mcp_server

# Optional: elicitation mode
# "llm"   — LLM auto-selects tradeoffs (default, fully agentic)
# "human" — graph pauses via interrupt() for a human to supply the selection
# ELICITATION_MODE=llm

# Optional: which OpenAI model to use for sampling + elicitation
# LLM_MODEL=gpt-4o-mini
